{
  "name": "coaster",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:web": "npm run start -w apps/web",
    "start:api": "npm run start:dev -w apps/api",
    "dev:emulators": "firebase emulators:start --only auth",
    "test": "npm test --workspaces --if-present"
  }
}
