{
  "name": "coaster",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "test:cov": "npm run test:cov --workspaces --if-present",
    "db:migrate": "docker compose exec api npx prisma migrate dev",
    "db:generate": "docker compose exec api npx prisma generate",
    "db:studio": "docker compose exec api npx prisma studio"
  },
  "devDependencies": {
    "@angular/compiler": "^22.0.5"
  }
}
