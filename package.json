{
  "name": "coaster",
  "version": "0.0.0",
  "scripts": {
"ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:functions": "npm run build --prefix functions",
    "build:functions:watch": "npm run build:watch --prefix functions",
    "emulators": "firebase emulators:start --import=./firebase-data --export-on-exit"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.10.1",
  "dependencies": {
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@capacitor/core": "^8.1.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@angular/fire": "^21.0.0-rc.0",
    "@capacitor/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.0",
    "firebase": "^12.9.0",
    "firebase-tools": "^15.7.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}