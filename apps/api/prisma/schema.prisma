// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/core/db/client"
}

datasource db {
  provider = "postgresql"
}

enum DbBarRole {
  OWNER
  MANAGER
  STAFF

  @@map("BarRole")
}

enum DbRole {
  USER
  ADMIN

  @@map("Role")
}

enum DbSubscriptionPlan {
  FREE
  PRO_MONTHLY
  PRO_YEARLY

  @@map("SubscriptionPlan")
}

enum DbSubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID

  @@map("SubscriptionStatus")
}

enum DbTableStatus {
  FREE
  OCCUPIED

  @@map("TableStatus")
}

enum DbOrderStatus {
  OPEN
  CLOSED
  CANCELLED

  @@map("OrderStatus")
}

enum DbPaymentStatus {
  PENDING
  PARTIAL
  PAID

  @@map("PaymentStatus")
}

enum DbPaymentMethod {
  CASH
  CARD
  MIXED
  NONE

  @@map("PaymentMethod")
}

enum DbDeliveryStatus {
  PENDING
  PARTIAL
  SERVED

  @@map("DeliveryStatus")
}

enum DbAdjustmentType {
  PERCENTAGE
  FIXED_AMOUNT

  @@map("AdjustmentType")
}

enum DbAdjustmentTarget {
  ORDER
  ITEM

  @@map("AdjustmentTarget")
}

model DbOrderAdjustment {
  id        String             @id @default(uuid())
  orderId   String
  order     DbOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  target    DbAdjustmentTarget
  itemId    String?
  item      DbOrderItem?       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      DbAdjustmentType
  value     Int
  reason    String?
  createdAt DateTime           @default(now())

  @@map("OrderAdjustment")
}

model DbUser {
  id             String            @id @default(uuid())
  email          String            @unique
  googleId       String?           @unique
  name           String
  photoUrl       String?
  active         Boolean           @default(true)
  role           DbRole            @default(USER)
  language       String            @default("es")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  memberships    DbBarMember[]
  shifts         DbShift[]
  shiftRequests  DbShiftExchange[] @relation("Requester")
  shiftApprovals DbShiftExchange[] @relation("Target")

  @@map("User")
}

model DbBar {
  id         String             @id @default(uuid())
  name       String
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  members    DbBarMember[]
  shifts     DbShift[]
  categories DbCategory[]
  tables     DbTable[]
  orders     DbOrder[]
  printer    DbPrinterConfig?
  billing    DbBarSubscription?

  @@map("Bar")
}

model DbBarMember {
  id        String    @id @default(uuid())
  userId    String
  user      DbUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  barId     String
  bar       DbBar     @relation(fields: [barId], references: [id], onDelete: Cascade)
  role      DbBarRole @default(STAFF)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, barId])
  @@map("BarMember")
}

model DbShift {
  id        String           @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  userId    String
  user      DbUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  barId     String
  bar       DbBar            @relation(fields: [barId], references: [id], onDelete: Cascade)
  notes     String?
  exchange  DbShiftExchange?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Shift")
}

model DbShiftExchange {
  id          String   @id @default(uuid())
  shiftId     String   @unique
  shift       DbShift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requesterId String
  requester   DbUser   @relation("Requester", fields: [requesterId], references: [id])
  targetId    String?
  target      DbUser?  @relation("Target", fields: [targetId], references: [id])
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  @@map("ShiftExchange")
}

model DbCategory {
  id        String      @id @default(uuid())
  barId     String
  bar       DbBar       @relation(fields: [barId], references: [id], onDelete: Cascade)
  name      String
  icon      String?
  products  DbProduct[]
  deletedAt DateTime?

  @@map("Category")
}

model DbProduct {
  id            String        @id @default(uuid())
  name          String
  price         Int           @default(0)
  categoryId    String
  category      DbCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  currentStock  Int           @default(0)
  minStockAlert Int           @default(0)
  imageUrl      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  orderItems    DbOrderItem[]

  @@map("Product")
}

model DbCategoryTemplate {
  id        String              @id @default(uuid())
  name      String
  icon      String?
  products  DbProductTemplate[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@map("CategoryTemplate")
}

model DbProductTemplate {
  id         String             @id @default(uuid())
  name       String
  price      Int                @default(0)
  categoryId String
  category   DbCategoryTemplate @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  imageUrl   String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@map("ProductTemplate")
}

model DbTable {
  id        String        @id @default(uuid())
  name      String
  status    DbTableStatus @default(FREE)
  barId     String
  bar       DbBar         @relation(fields: [barId], references: [id], onDelete: Cascade)
  orders    DbOrder[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("Table")
}

model DbOrder {
  id             String              @id @default(uuid())
  barId          String
  bar            DbBar               @relation(fields: [barId], references: [id], onDelete: Cascade)
  tableId        String?
  table          DbTable?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  tableName      String?
  status         DbOrderStatus       @default(OPEN)
  totalAmount    Int                 @default(0)
  amountPaidCash Int                 @default(0)
  amountPaidCard Int                 @default(0)
  items          DbOrderItem[]
  adjustments    DbOrderAdjustment[]
  paymentMethod  DbPaymentMethod     @default(NONE)
  notes          String?
  tipAmount      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("Order")
}

model DbOrderItem {
  id               String              @id @default(uuid())
  orderId          String
  order            DbOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  product          DbProduct           @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity         Int
  priceAtPurchase  Int
  paidQuantity     Int                 @default(0)
  paidQuantityCash Int                 @default(0)
  paidQuantityCard Int                 @default(0)
  servedQuantity   Int                 @default(0)
  paymentStatus    DbPaymentStatus     @default(PENDING)
  deliveryStatus   DbDeliveryStatus    @default(PENDING)
  paymentMethod    DbPaymentMethod     @default(NONE)
  notes            String?
  adjustments      DbOrderAdjustment[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("OrderItem")
}

model DbPrinterConfig {
  id         String    @id @default(uuid())
  barId      String    @unique
  bar        DbBar     @relation(fields: [barId], references: [id], onDelete: Cascade)
  deviceKey  String    @default(uuid())
  ipAddress  String?
  port       Int       @default(8080)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("PrinterConfig")
}

model DbBarSubscription {
  id                   String               @id @default(uuid())
  barId                String               @unique
  bar                  DbBar                @relation(fields: [barId], references: [id], onDelete: Cascade)
  plan                 DbSubscriptionPlan   @default(FREE)
  status               DbSubscriptionStatus @default(INACTIVE)
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean              @default(false)
  canceledAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([status])
  @@map("BarSubscription")
}

model DbStripeWebhookEvent {
  id            String   @id @default(uuid())
  stripeEventId String   @unique
  type          String
  payload       Json
  processedAt   DateTime @default(now())

  @@map("StripeWebhookEvent")
}
